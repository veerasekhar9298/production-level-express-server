    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsc-watch": "^7.2.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  },
  "lint-staged": {
    "*.{ts,js}": [
