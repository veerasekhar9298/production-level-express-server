    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "body-parser": "^2.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-basic-auth": "^1.2.1",
    "graphql": "^16.13.2",
    "moment": "^2.30.1",
    "passport": "^0.7.0",
    "pino-http": "^11.0.0",
    "qs": "^6.15.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
